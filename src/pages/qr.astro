---
import QRCode from "qrcode";

const url = "https://альянсвк.рф";
const svg = await QRCode.toString(url, {
  type: "svg",
  width: 280,
  margin: 2,
  color: { dark: "#1F2421", light: "#FFFFFF" },
});
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>QR-код — Альянс ВК</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: #F5F0EB;
        font-family: Inter, system-ui, sans-serif;
      }
      .card {
        background: #fff;
        border-radius: 1.5rem;
        padding: 2.5rem;
        text-align: center;
        box-shadow: 0 8px 40px rgba(31,36,33,0.12);
        max-width: 360px;
        width: 100%;
      }
      .qr { display: block; margin: 0 auto; }
      .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 1.5rem;
        text-decoration: none;
      }
      .logo-icon {
        width: 40px; height: 40px;
        background: #1F2421;
        border-radius: 10px;
        display: grid;
        place-items: center;
        color: #F5F0EB;
        font-size: 18px;
        font-weight: 900;
      }
      .logo-text { text-align: left; }
      .logo-name { display: block; font-size: 15px; font-weight: 900; color: #1F2421; line-height: 1.2; }
      .logo-sub { display: block; font-size: 11px; color: #6b625c; margin-top: 2px; }
      .domain {
        display: block;
        margin-top: 1.25rem;
        font-size: 13px;
        color: #6b625c;
        letter-spacing: 0.03em;
      }
      .accent { color: #C9362C; }
      .hint {
        margin-top: 1rem;
        font-size: 11px;
        color: #aaa;
      }
      @media print {
        body { background: white; }
        .card { box-shadow: none; }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <Fragment set:html={svg} />
      <a class="logo" href="https://альянсвк.рф">
        <span class="logo-icon">A</span>
        <span class="logo-text">
          <span class="logo-name">Альянс ВК</span>
          <span class="logo-sub">мебель на заказ в Новороссийске</span>
        </span>
      </a>
      <span class="domain"><span class="accent">альянсвк</span>.рф</span>
      <p class="hint">Отсканируйте камерой телефона</p>
    </div>
  </body>
</html>
