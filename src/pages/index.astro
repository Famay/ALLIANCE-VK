---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Popular from "../components/Popular.astro";
import Advantages from "../components/Advantages.astro";
import Promos from "../components/Promos.astro";
import Projects from "../components/Projects.astro";
import Process from "../components/Process.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Chatbot from "../components/Chatbot.astro";

const title = "Альянс ВК — мебель на заказ в Новороссийске | кухни, шкафы, гардеробные";
const description = "Альянс ВК — производство мебели на заказ в Новороссийске. Кухни, шкафы, шкафы-купе, гардеробные, прихожие. Бесплатный замер и 3D-проект. Звоните: +7 918 657-79-00.";
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Services />
    <Popular />
    <Advantages />
    <Promos />
    <Projects />
    <Process />
    <Contact />
  </main>
  <Footer />
  <Chatbot />
</BaseLayout>
