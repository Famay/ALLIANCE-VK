---
import { advantages } from "../data/site";
---

<section class="section bg-white">
  <div class="container grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-stretch">
    <article class="relative min-h-[560px] overflow-hidden rounded-[1.8rem] text-white">
      <img class="absolute inset-0 size-full object-cover" src="/furniture/dressing-01.jpg" alt="Система хранения на заказ" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
      <div class="absolute bottom-0 left-0 max-w-2xl p-7 lg:p-10">
        <p class="text-sm font-black uppercase text-white/70">Культ хранения</p>
        <h2 class="display-heading mt-4 text-5xl leading-none lg:text-6xl">Пусть все будет на своих местах</h2>
        <p class="mt-5 text-lg leading-8 text-white/76">
          Красивый дом начинается с порядка. Мы проектируем хранение так, чтобы повседневные вещи не спорили с интерьером.
        </p>
      </div>
    </article>

    <div class="rounded-[1.8rem] bg-[var(--light-color)] p-6 lg:p-8">
      <p class="eyebrow">Преимущества</p>
      <h3 class="display-heading mt-3 text-5xl leading-none text-[var(--main-color)]">Почему это удобно</h3>
      <div class="mt-8 grid gap-0 divide-y divide-[var(--border-color)]">
        {
          advantages.map((item, index) => (
            <div class="grid grid-cols-[52px_1fr] gap-4 py-5">
              <span class="text-sm font-black text-[var(--primary-color)]">{String(index + 1).padStart(2, "0")}</span>
              <p class="text-xl font-semibold text-[var(--main-color)]">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
