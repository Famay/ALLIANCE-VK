---
import { quickCategories, site } from "../data/site";
---

<section id="contacts" class="section bg-[#efe7dc]">
  <div class="container grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="eyebrow">Расчет проекта</p>
      <h2 class="mt-3 text-4xl font-black text-[#1f2421]">Получите ориентир по цене и срокам</h2>
      <p class="mt-4 text-lg leading-8 text-[#6b625c]">
        Оставьте контакты и коротко опишите задачу. Для точного расчета можно будет отправить фото, размеры или план помещения.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <div class="rounded-lg bg-white p-5">
          <p class="text-sm font-bold text-[#85786f]">Телефон</p>
          <a class="mt-2 block text-xl font-black text-[#1f2421] no-underline hover:text-[#c9362c]" href={`tel:${site.phone}`}>{site.phone}</a>
          <a class="mt-1 block text-xl font-black text-[#1f2421] no-underline hover:text-[#c9362c]" href={`tel:${site.phone2}`}>{site.phone2}</a>
        </div>
        <div class="rounded-lg bg-white p-5">
          <p class="text-sm font-bold text-[#85786f]">Сообщения</p>
          <a class="mt-2 block text-xl font-black text-[#1f2421] no-underline hover:text-[#c9362c]" href={site.messenger}>Написать сейчас</a>
        </div>
        <div class="rounded-lg bg-white p-5 sm:col-span-2">
          <p class="text-sm font-bold text-[#85786f]">Адрес</p>
          <p class="mt-2 text-xl font-black text-[#1f2421]">{site.address}</p>
          <p class="mt-1 text-sm text-[#85786f]">{site.city}</p>
        </div>
      </div>
    </div>

    <form class="rounded-lg bg-white p-5 shadow-[0_18px_60px_rgba(31,36,33,0.1)]" id="contactForm" action="/send.php" method="post">
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
      <div class="grid gap-4 md:grid-cols-2">
        <label class="grid gap-2 text-sm font-bold text-[#2d2b29]">
          Имя
          <input class="min-h-12 rounded-lg border border-[#ded4c8] bg-white px-4 outline-none focus:border-[#c9362c]" name="name" placeholder="Как к вам обращаться" required />
        </label>
        <label class="grid gap-2 text-sm font-bold text-[#2d2b29]">
          Телефон
          <input class="min-h-12 rounded-lg border border-[#ded4c8] bg-white px-4 outline-none focus:border-[#c9362c]" name="phone" id="phoneInput" placeholder="+7 (___) ___-__-__" inputmode="tel" required />
        </label>
      </div>

      <div class="mt-5">
        <p class="text-sm font-bold text-[#2d2b29]">Что нужно сделать</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            quickCategories.map((item) => (
              <label class="cursor-pointer rounded-lg border border-[#ded4c8] px-3 py-2 text-sm font-bold text-[#5b5148] has-[:checked]:border-[#c9362c] has-[:checked]:bg-[#fff2ef] has-[:checked]:text-[#c9362c]">
                <input class="sr-only" type="checkbox" name="category" value={item.title} />
                {item.title}
              </label>
            ))
          }
        </div>
      </div>

      <label class="mt-5 grid gap-2 text-sm font-bold text-[#2d2b29]">
        Комментарий
        <textarea class="min-h-32 rounded-lg border border-[#ded4c8] bg-white p-4 outline-none focus:border-[#c9362c]" name="message" placeholder="Размеры, примерный бюджет, материалы, сроки"></textarea>
      </label>

      <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
        <button class="btn btn-primary" type="submit" id="contactSubmit">Отправить заявку</button>
        <p class="text-xs leading-5 text-[#85786f]">Нажимая кнопку, вы соглашаетесь на обработку персональных данных.</p>
      </div>
      <p id="contactResult" class="mt-3 hidden text-sm font-bold"></p>
    </form>

<script>
  // Phone mask: +7 (___) ___-__-__
  const phoneInput = document.getElementById('phoneInput') as HTMLInputElement;
  phoneInput?.addEventListener('input', () => {
    let v = phoneInput.value.replace(/\D/g, '');
    if (v.startsWith('8')) v = '7' + v.slice(1);
    if (!v.startsWith('7')) v = '7' + v;
    v = v.slice(0, 11);
    let out = '+7';
    if (v.length > 1) out += ' (' + v.slice(1, 4);
    if (v.length >= 4) out += ') ' + v.slice(4, 7);
    if (v.length >= 7) out += '-' + v.slice(7, 9);
    if (v.length >= 9) out += '-' + v.slice(9, 11);
    phoneInput.value = out;
  });
  phoneInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Backspace' && phoneInput.value === '+7') e.preventDefault();
  });
  phoneInput?.addEventListener('focus', () => {
    if (!phoneInput.value) phoneInput.value = '+7';
  });

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btn  = document.getElementById('contactSubmit') as HTMLButtonElement;
  const result = document.getElementById('contactResult') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Отправляем…';
    result.className = 'mt-3 hidden text-sm font-bold';

    const formData = new FormData(form);
    const body = new URLSearchParams();
    for (const [key, val] of formData) {
      body.append(key, val as string);
    }
    body.set('source', 'form');

    try {
      const res = await fetch('/send.php', { method: 'POST', body });
      const data = await res.json();
      if (data.success) {
        result.textContent = '✅ Заявка отправлена! Свяжемся с вами в ближайшее время.';
        result.className = 'mt-3 text-sm font-bold text-green-700';
        form.reset();
      } else {
        throw new Error(data.error || 'Ошибка');
      }
    } catch {
      result.textContent = '❌ Не удалось отправить. Позвоните нам или напишите в ВК.';
      result.className = 'mt-3 text-sm font-bold text-red-600';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Отправить заявку';
      result.classList.remove('hidden');
    }
  });
</script>
  </div>
</section>
