---
import { promos } from "../data/site";
---

<section id="promos" class="section bg-[var(--light-color)]">
  <div class="container">
    <div class="flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="eyebrow">Акции</p>
        <h2 class="display-heading mt-3 text-5xl leading-none text-[var(--main-color)] lg:text-6xl">Выгодные условия для проекта</h2>
      </div>
      <a class="btn btn-secondary" href="#contacts">Все предложения</a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
      {
        promos.map((promo) => (
          <article class="flex min-h-64 flex-col justify-between rounded-[1.35rem] bg-white p-6">
            <div>
              <p class="text-sm font-black uppercase text-[var(--primary-color)]">Предложение</p>
              <h3 class="mt-4 text-2xl font-black leading-tight text-[var(--main-color)]">{promo.title}</h3>
            </div>
            <a class="mt-8 inline-flex text-sm font-black text-[var(--primary-color)]" href="#contacts">{promo.action}</a>
          </article>
        ))
      }
    </div>
  </div>
</section>
