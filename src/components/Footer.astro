---
import { navigation, quickCategories, site } from "../data/site";
---

<footer class="bg-[#1f2421] py-10 text-white">
  <div class="container grid gap-8 md:grid-cols-[1.2fr_1fr_1fr]">
    <div>
      <a class="flex items-center gap-3 text-white no-underline" href="/">
        <span class="grid size-10 place-items-center rounded-lg bg-[#c9362c] text-lg font-black">A</span>
        <span>
          <span class="block text-base font-black leading-tight">{site.name}</span>
          <span class="block text-xs font-semibold text-white/60">мебель на заказ в {site.city}</span>
        </span>
      </a>
      <p class="mt-5 max-w-sm leading-7 text-white/65">
        Проектирование, производство и монтаж кухонь, шкафов, гардеробных и корпусной мебели под размер.
      </p>
    </div>

    <nav class="grid gap-3 text-sm font-bold text-white/70">
      {navigation.map((item) => <a class="hover:text-white" href={item.href}>{item.title}</a>)}
    </nav>

    <div class="grid gap-3 text-sm font-bold text-white/70">
      {quickCategories.map((item) => <a class="hover:text-white" href={item.href}>{item.title}</a>)}
      <a class="mt-3 text-white" href={`tel:${site.phone}`}>{site.phone}</a>
      <a class="hover:text-white" href={site.vk}>ВКонтакте</a>
    </div>
  </div>
</footer>
