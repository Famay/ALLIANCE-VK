---
import { process, productionStats } from "../data/site";
---

<section id="process" class="section bg-white">
  <div class="container">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="eyebrow">Производство</p>
        <h2 class="display-heading mt-3 text-5xl leading-none text-[var(--main-color)] lg:text-6xl">Проект проходит понятный путь</h2>
        <p class="mt-5 text-lg leading-8 text-[var(--muted-color)]">
          От первой консультации до монтажа проект ведется по этапам: клиент понимает сроки, состав мебели и финальную стоимость.
        </p>
      </div>

      <ol class="divide-y divide-[var(--border-color)] rounded-[1.4rem] border border-[var(--border-color)] bg-white">
        {
          process.map((item, index) => (
            <li class="grid gap-4 p-6 sm:grid-cols-[56px_1fr] sm:items-center">
              <span class="text-sm font-black text-[var(--primary-color)]">{String(index + 1).padStart(2, "0")}</span>
              <p class="text-xl font-semibold text-[var(--main-color)]">{item}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="mt-10 grid overflow-hidden rounded-[1.8rem] bg-[var(--main-color)] text-white lg:grid-cols-[1.15fr_0.85fr]">
      <div class="min-h-[420px]">
        <img class="size-full object-cover" src="/reference/mix22.jpg" alt="Производство мебели на заказ" loading="lazy" />
      </div>
      <div class="p-7 lg:p-10">
        <h3 class="display-heading text-5xl leading-none">Мебель под размер помещения</h3>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {
            productionStats.map((item) => (
              <div>
                <p class="text-4xl font-black">{item.value}</p>
                <p class="mt-2 text-sm leading-6 text-white/70">{item.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
