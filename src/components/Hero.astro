---
import { accessoryLinks, quickCategories, site, stats } from "../data/site";
---

<section class="hero-cover relative min-h-screen overflow-hidden text-white">
  <img
    class="absolute inset-0 size-full object-cover"
    src="/furniture/kitchen-01.jpg"
    alt="Светлый интерьер с мебелью на заказ"
  />
  <div class="absolute inset-0 bg-[radial-gradient(circle_closest-corner_at_30px_20px,rgba(0,0,0,0)_0%,rgba(0,0,0,.24)_85%)]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-black/35"></div>

  <div class="container relative flex min-h-screen flex-col justify-end pb-6 pt-32 lg:pb-8 lg:pt-44">
    <div class="max-w-4xl pb-8">
      <p class="text-sm font-black uppercase text-white/75">Мебель на заказ в {site.city}</p>
      <h1 class="display-title mt-5 max-w-4xl text-6xl leading-[0.92] sm:text-7xl lg:text-8xl">
        Мебель точно под вас
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-8 text-white/78">
        Делаем кухни, шкафы, гардеробные и мебель для всего дома по вашим размерам. Замер, проект и консультация — бесплатно.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="btn btn-primary" href="#contacts">Рассчитать стоимость</a>
        <a class="btn btn-inversed" href="#projects">Смотреть работы</a>
      </div>
    </div>

    <div class="grid gap-3 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="glass-line grid gap-2 rounded-2xl p-2 sm:grid-cols-2 lg:grid-cols-5">
        {
          quickCategories.map((item) => (
            <a class="group relative min-h-28 overflow-hidden rounded-xl text-white no-underline" href={item.href}>
              <img class="absolute inset-0 size-full object-cover transition duration-500 group-hover:scale-105" src={item.image} alt={item.title} loading="lazy" />
              <span class="absolute inset-0 bg-gradient-to-t from-black/60 to-black/10"></span>
              <span class="absolute bottom-3 left-3 right-3 text-lg font-black">{item.title}</span>
            </a>
          ))
        }
      </div>

      <div class="glass-line grid min-w-72 grid-cols-2 gap-3 rounded-2xl p-4">
        {
          stats.map((item) => (
            <div>
              <p class="text-2xl font-black">{item.value}</p>
              <p class="mt-1 text-xs leading-5 text-white/68">{item.label}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-3 flex flex-wrap gap-2 text-sm font-bold text-white/78">
      {accessoryLinks.map((item) => <a class="rounded-full bg-white/10 px-4 py-2 hover:bg-white/20 hover:text-white" href="#services">{item}</a>)}
    </div>
  </div>
</section>
